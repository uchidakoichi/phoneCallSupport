# Groq API Key（台本生成・Whisper文字起こし用）
# https://console.groq.com でAPIキーを取得
GROQ_API_KEY=gsk_...

# Hume AI API Key（音読練習の声分析用・任意）
# https://platform.hume.ai でAPIキーを取得
HUME_API_KEY=...

# Supabase（クラウド同期用）
# https://supabase.com でプロジェクトを作成し、Settings > API からコピー
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
